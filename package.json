{
  "name": "Idemy",
  "version": "2.0.1",
  "description": "A desktop application for managing and watching video courses, built with Electron, React, and TypeScript.",
  "main": "./out/main/index.mjs",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "postinstall": "electron-builder install-app-deps && node scripts/compile-helper.js",
    "dev": "node scripts/compile-helper.js && electron-vite dev",
    "test": "vitest run",
    "build": "node scripts/compile-helper.js && electron-vite build",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "preview": "electron-vite preview",
    "start": "electron-vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinifloriano/idemy2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/vinifloriano/idemy2/issues"
  },
  "homepage": "https://github.com/vinifloriano/idemy2#readme",
  "build": {
    "appId": "com.idemy.app",
    "productName": "Idemy",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.education",
      "target": [
        "dmg"
      ],
      "extendInfo": {
        "NSSpeechRecognitionUsageDescription": "Idemy uses Speech Recognition to transcribe video and microphone audio into text.",
        "NSMicrophoneUsageDescription": "Idemy needs microphone access for live audio transcription."
      },
      "extraResources": [
        {
          "from": "src/main/native/apple-speech-helper",
          "to": "apple-speech-helper"
        }
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "src/main/native/windows-speech-helper.ps1",
          "to": "windows-speech-helper.ps1"
        }
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@xenova/transformers": "^2.17.2",
    "emoji-picker-react": "^4.19.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sqlite3": "6.0.1",
    "uuid": "14.0.0",
    "wavefile": "^11.0.0",
    "ytdlp-nodejs": "^3.4.4",
    "ytpl": "^2.3.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.2",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/eslint__js": "^8.42.3",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.5.0",
    "electron": "42.3.3",
    "electron-builder": "26.15.2",
    "electron-vite": "5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.9.0",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
